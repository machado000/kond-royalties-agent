OPENAI_API_KEY=<SECRET>
OPENAI_MODEL=gpt-4.1-mini

# Opcao A: um unico DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:5432/kond

# Opcao B: variaveis PG* padrao do libpq (usada se DATABASE_URL nao estiver definido)
PGHOST=host
PGPORT=5432
PGDATABASE=kond
PGUSER=user
PGPASSWORD=<SECRET>
PGSSLMODE=require

POSTGRES_SCHEMAS=public,universal,warner_chappell

# --- Transporte HTTP remoto (serve-http), opcional, so necessario para hospedagem compartilhada ---

# Tokens Bearer estaticos (lista separada por virgula) -- caminho simples para
# clientes ja configurados manualmente (Antigravity, scripts). O processo
# recusa iniciar sem MCP_API_KEYS ou OAUTH_ISSUER_URL/OAUTH_RESOURCE_URL.
MCP_API_KEYS=<SECRET>
# Hosts reais (dominio[:porta]) deste deploy, para a protecao contra DNS
# rebinding do SDK `mcp`.
MCP_ALLOWED_HOSTS=seu-dominio.com,seu-dominio.com:8080

# Delegacao OAuth 2.1 (Auth0 ou IdP compativel) -- necessario para clientes
# que fazem o fluxo OAuth completo (ex.: conector remoto do claude.ai).
# Coexiste com MCP_API_KEYS: o servidor tenta o token estatico primeiro,
# depois valida como JWT do IdP. Se o IdP for Auth0, habilitar "Resource
# Parameter Compatibility Profile" em Settings -> Advanced -- ver README.md.
# OAUTH_ISSUER_URL=https://seu-tenant.us.auth0.com
# OAUTH_RESOURCE_URL=https://seu-dominio.com/kond-royalties-mcp/mcp
# OAUTH_JWKS_URL=  # opcional, descoberto via OpenID Connect Discovery (OAUTH_ISSUER_URL + /.well-known/openid-configuration) se omitido
# OAUTH_REQUIRED_SCOPES=  # opcional, lista separada por virgula
